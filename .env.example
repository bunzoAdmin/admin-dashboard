# qcom admin API (login, riders, orders, disputes — not inventory microservices)
NEXT_PUBLIC_API_BASE_URL=https://api.bunzodelivery.com

# --- Inventory microservices (catalog, inventory, images, picker admin) ---
#
# Browser uses same-origin /api/v1/* route handlers — no public URL env required.
# Server-side proxy targets (required on Vercel):
PRODUCT_SERVICE_PROXY_TARGET=http://localhost:8081/product-service
ORDER_SERVICE_PROXY_TARGET=http://localhost:8082/order-service
SEARCH_SERVICE_PROXY_TARGET=http://localhost:8083/search-service
#
# Local dev (search-service requires HTTP basic auth on /admin/**):
# SEARCH_SERVICE_PROXY_TARGET=http://localhost:8083
# SEARCH_SERVICE_BASIC_AUTH=Basic YWRtaW46YWRtaW4xMjM=
#
# Vercel production:
# PRODUCT_SERVICE_PROXY_TARGET=https://api.bunzodelivery.com/product-service
# ORDER_SERVICE_PROXY_TARGET=https://api.bunzodelivery.com/order-service
# SEARCH_SERVICE_PROXY_TARGET=https://api.bunzodelivery.com/search-service
#
# Optional: only if the dashboard UI is hosted separately from the API routes
# NEXT_PUBLIC_INVENTORY_API_BASE_URL=https://your-admin-app.vercel.app
#
# Remove legacy vars if still set (they break HTTPS → http:// mixed-content):
# NEXT_PUBLIC_CATALOG_API_BASE_URL, NEXT_PUBLIC_ORDER_API_BASE_URL

# Local dev only: pins the store selector to a fixed ID, skipping the darkstores API call.
# Ignored automatically in production builds (NODE_ENV === 'production'), even if set here —
# do NOT rely on unsetting this in prod hosting env vars; it's a defense-in-depth guard too.
NEXT_PUBLIC_DEFAULT_STORE_ID=1

# Public CDN / MinIO prefix for catalog R2 keys (category & product image previews in admin).
# Dev (MinIO): http://localhost:9000/product-images
#   Bucket must allow anonymous download — run: ../inventory/scripts/setup-minio-local.sh
# Prod (Cloudflare): https://cdn.yourapp.zm/cdn-cgi/image/w=400,h=400,fit=cover,f=auto,q=80
NEXT_PUBLIC_CATALOG_IMAGE_BASE_URL=http://localhost:9000/product-images
