# qcom admin API (riders, orders, disputes, auth)
NEXT_PUBLIC_API_BASE_URL=https://api.bunzodelivery.com

# Catalog + inventory API base URL (browser fetch target).
#
# Option A — direct product-service (local HTTP or same-scheme only):
#   NEXT_PUBLIC_CATALOG_API_BASE_URL=http://15.135.73.205:8081
#   Requires CORS_ALLOWED_ORIGINS on product-service to include your dashboard origin.
#   Does NOT work from https://*.vercel.app → http://IP (browser mixed-content block).
#
# Option B — local dev (route handlers proxy to product-service / order-service):
#   NEXT_PUBLIC_CATALOG_API_BASE_URL=http://localhost:3100
#   CATALOG_PROXY_TARGET=http://localhost:8081
#   NEXT_PUBLIC_ORDER_API_BASE_URL=http://localhost:3100
#   ORDER_PROXY_TARGET=http://localhost:8082
#
# Option C — Vercel production:
#   NEXT_PUBLIC_CATALOG_API_BASE_URL=https://your-admin-app.vercel.app
#   CATALOG_PROXY_TARGET=http://15.135.73.205:8081
#   NEXT_PUBLIC_ORDER_API_BASE_URL=https://your-admin-app.vercel.app
#   ORDER_PROXY_TARGET=http://<order-service-host>:8082
# All /api/v1/catalog|inventory|images|admin/* calls use Next.js route handlers (not rewrites).
NEXT_PUBLIC_CATALOG_API_BASE_URL=http://localhost:3100
CATALOG_PROXY_TARGET=http://localhost:8081

# Default store for inventory inwarding (store ID field on /inventory)
NEXT_PUBLIC_DEFAULT_STORE_ID=1

# Public CDN / MinIO prefix for catalog R2 keys (category & product image previews in admin).
# Dev (MinIO): http://localhost:9000/product-images
# Prod (Cloudflare): https://cdn.yourapp.zm/cdn-cgi/image/w=400,h=400,fit=cover,f=auto,q=80
# NEXT_PUBLIC_CATALOG_IMAGE_BASE_URL=http://localhost:9000/product-images

# Order / picker admin API (local: same origin with Next rewrites to order-service :8082)
NEXT_PUBLIC_ORDER_API_BASE_URL=http://localhost:3100
# ORDER_PROXY_TARGET=http://localhost:8082
